---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Sidebar from '../components/Sidebar.astro';
import TwikooComments from '../components/TwikooComments.astro';
import { resolveContentDate } from '../utils/dates';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags = [], heroImage, entryFilePath } = Astro.props;
const typeLabel = Astro.props.type === 'short' ? '说说' : '笔记';
const resolvedPubDate = resolveContentDate(pubDate, entryFilePath, 'pubDate');
const resolvedUpdatedDate = updatedDate
	? resolveContentDate(updatedDate, entryFilePath, 'updatedDate')
	: undefined;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<div class="page-shell">
			<Sidebar />
			<main class="page-content">
				<article class="article-card">
					<header class="article-card__header">
						<p class="article-card__eyebrow">{typeLabel}</p>
						<h1>{title}</h1>
						<p class="article-card__desc">{description}</p>
						<div class="article-card__meta">
							<span><FormattedDate date={resolvedPubDate} showTime={true} /></span>
							{
								resolvedUpdatedDate && (
									<span>更新于 <FormattedDate date={resolvedUpdatedDate} showTime={true} /></span>
								)
							}
						</div>
						{
							tags.length > 0 && (
								<div class="article-card__tags">
									{tags.map((tag: string) => <span>{tag}</span>)}
								</div>
							)
						}
					</header>
					{
						heroImage && (
							<div class="article-card__cover">
								<img src={heroImage.src} alt={title} />
							</div>
						)
					}
					<div class="prose">
						<slot />
					</div>
				</article>
				<TwikooComments />
			</main>
		</div>
	</body>
</html>
