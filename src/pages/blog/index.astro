---
import { getCollection } from 'astro:content';
import ArchiveGroups from '../../components/ArchiveGroups.astro';
import SearchToolbar from '../../components/SearchToolbar.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import { getComparableTime } from '../../utils/dates';

const posts = (await getCollection('blog')).sort(
	(a, b) => getComparableTime(b.data.pubDate) - getComparableTime(a.data.pubDate),
);
---

<MainLayout title="归档" description="Astro 博客文章归档">
	<SearchToolbar placeholder="搜索归档文章..." />
	<section class="section-card">
		<div class="section-card__head">
			<h1>归档</h1>
			<span>{posts.length} 篇文章</span>
		</div>
		<ArchiveGroups posts={posts} />
	</section>
</MainLayout>
