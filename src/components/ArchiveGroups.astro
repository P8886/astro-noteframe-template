---
import type { CollectionEntry } from 'astro:content';
import { formatMonthDay, formatTime } from '../utils/dates';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const groups = Object.entries(
	posts.reduce<Record<string, CollectionEntry<'blog'>[]>>((acc, post) => {
		const year = String(post.data.pubDate.value.getFullYear());
		acc[year] ??= [];
		acc[year].push(post);
		return acc;
	}, {}),
).sort((a, b) => Number(b[0]) - Number(a[0]));

const typeLabel = {
	note: '笔记',
	short: '说说',
};
---

<div class="archive-groups">
	{
		groups.map(([year, yearPosts]) => (
			<section class="archive-group">
				<h2 class="archive-group__year">{year}年</h2>
				<div class="archive-group__list">
					{
						yearPosts.map((post) => (
							<a
								class="archive-item"
								href={`/blog/${post.id}/`}
								data-search-text={`${post.data.title} ${post.data.description} ${post.data.tags?.join(' ') ?? ''} ${typeLabel[post.data.type]}`.toLowerCase()}
							>
								<div class="archive-item__date">
									<span>{formatMonthDay(post.data.pubDate)}</span>
									{post.data.pubDate.hasExplicitTime && <time>{formatTime(post.data.pubDate)}</time>}
								</div>
								<div class="archive-item__main">
									<div class="archive-item__tags">
										<span class:list={['type-badge', post.data.type === 'short' ? 'type-badge--short' : 'type-badge--note']}>
											{typeLabel[post.data.type]}
										</span>
										{post.data.tags.map((tag) => <span class="archive-tag">{tag}</span>)}
									</div>
									<h3>{post.data.title}</h3>
								</div>
							</a>
						))
					}
				</div>
			</section>
		))
	}
</div>
