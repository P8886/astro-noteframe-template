---
const envId = import.meta.env.PUBLIC_TWIKOO_ENV_ID ?? '';
const path = Astro.props.path ?? Astro.url.pathname;
---

<section class="comment-panel">
	<h2>评论</h2>
	<p class="comment-panel__hint">
		支持昵称、邮箱、个人网站。回复通知可通过 Twikoo 的邮件配置实现。
	</p>
	{
		envId ? (
			<div id="twikoo" />
		) : (
			<div class="comment-panel__empty">
				<p>还没有配置评论服务。</p>
				<p>在 `.env` 中设置 `PUBLIC_TWIKOO_ENV_ID` 后即可启用。</p>
			</div>
		)
	}
</section>

{
	envId && (
		<script is:inline define:vars={{ envId, path }}>
			const loadTwikoo = async () => {
				if (window.twikoo) {
					window.twikoo.init({
						envId,
						el: '#twikoo',
						path,
						lang: 'zh-CN',
					});
					return;
				}

				const script = document.createElement('script');
				script.src = 'https://cdn.jsdelivr.net/npm/twikoo@1.6.44/dist/twikoo.min.js';
				script.onload = () => {
					window.twikoo.init({
						envId,
						el: '#twikoo',
						path,
						lang: 'zh-CN',
					});
				};
				document.body.appendChild(script);
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', loadTwikoo, { once: true });
			} else {
				loadTwikoo();
			}
		</script>
	)
}
